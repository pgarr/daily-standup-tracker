---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { calculateStreak } from "@/lib/streak";
import { shouldSuggestBlockerMatch } from "@/lib/blocker";
import { haikuSimilarity } from "@/lib/similarity";
import type { BlockerAlert, StandupEntry } from "@/types";
import StandupForm from "@/components/standup/StandupForm";
import StandupHistoryList from "@/components/standup/StandupHistoryList";

const { user, workspace, workspaceMember } = Astro.locals;
const role = workspaceMember?.role === "team_lead" ? "Team Lead" : (workspaceMember?.role ?? "Member");

const supabase = createClient(Astro.request.headers, Astro.cookies);
let recentEntries: StandupEntry[] = [];
let todayEntry: StandupEntry | null = null;
let loadError: string | null = null;
let blockerAlerts: BlockerAlert[] = [];
let showBlockerBanner = false;

if (!user) return Astro.redirect("/auth/signin");

const today = new Date().toISOString().slice(0, 10);
const sixtyDaysAgo = new Date(Date.now() - 60 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
const isFreshSubmit = Astro.url.searchParams.get("blocker_match") === "1";

if (supabase) {
  const [{ data, error: queryError }, { data: alertData }] = await Promise.all([
    supabase
      .from("standup_entries")
      .select("*")
      .eq("user_id", user.id)
      .order("submitted_date", { ascending: false })
      .limit(60),
    supabase.from("blocker_alerts").select("*").eq("user_id", user.id).gte("trigger_date", sixtyDaysAgo).limit(90),
  ]);
  if (queryError) {
    loadError = "Failed to load standup entries. Please try refreshing.";
  } else {
    recentEntries = data as StandupEntry[];
    todayEntry = recentEntries.find((e) => e.submitted_date === today) ?? null;
  }
  if (alertData) blockerAlerts = alertData as BlockerAlert[];

  if (isFreshSubmit && todayEntry?.blockers) {
    try {
      const existingAlert = blockerAlerts.find((a) => a.trigger_date === today);
      if (!existingAlert) {
        showBlockerBanner = await shouldSuggestBlockerMatch(
          recentEntries,
          workspace?.alert_threshold ?? 2,
          haikuSimilarity,
        );
      }
    } catch (err) {
      console.error("[dashboard] blocker detection failed:", err);
    }
  }
}

const streak = calculateStreak(recentEntries);
const displayEntries = recentEntries.slice(0, 30);
const submitError = Astro.url.searchParams.get("error");
const successParam = Astro.url.searchParams.get("success");
const successMessage =
  successParam === "entry_updated" ? "Entry updated" : successParam === "entry_deleted" ? "Entry deleted" : null;
---

<AppLayout title="Dashboard">
  <div class="p-6">
    <!-- Header card -->
    <header
      class="mx-auto max-w-2xl rounded-2xl border border-white/10 bg-white/10 p-6 text-center text-white backdrop-blur-xl"
    >
      <h1 class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        {workspace?.name}
      </h1>
      <span
        class="inline-block rounded-full border border-purple-400/40 bg-purple-500/20 px-3 py-1 text-xs font-medium text-purple-200"
      >
        {role}
      </span>
      <p class="mt-3 text-sm text-blue-100/60">
        Signed in as <span class="font-medium text-white">{user.email}</span>
      </p>
    </header>

    <main class="mx-auto mt-6 max-w-2xl space-y-6">
      {
        loadError && (
          <div class="rounded-xl border border-red-500/30 bg-red-900/30 px-4 py-3 text-sm text-red-300">
            {loadError}
          </div>
        )
      }

      <!-- Streak badge -->
      {
        streak > 0 && (
          <div class="rounded-2xl border border-orange-400/30 bg-orange-500/10 px-6 py-4 text-center backdrop-blur-xl">
            <span class="text-2xl font-bold text-orange-200">🔥 Day {streak}</span>
            <p class="mt-1 text-sm text-orange-200/60">
              {streak === 1 ? "Keep it up!" : `${streak} consecutive business days`}
            </p>
          </div>
        )
      }

      <!-- Blocker match banner -->
      {
        showBlockerBanner && todayEntry && (
          <section class="rounded-2xl border border-amber-400/30 bg-amber-500/10 p-6 text-white backdrop-blur-xl">
            <h2 class="mb-2 text-base font-semibold text-amber-200">Recurring blocker detected</h2>
            <p class="mb-4 text-sm text-amber-100/70">
              It looks like you've been blocked by the same issue on consecutive days. Is this the same blocker?
            </p>
            <div class="mb-4 space-y-2">
              <div class="rounded-lg border border-amber-400/20 bg-amber-500/10 p-3">
                <p class="mb-0.5 text-xs font-medium tracking-wide text-amber-300/60 uppercase">Today</p>
                <p class="text-sm text-amber-100/90">{todayEntry.blockers}</p>
              </div>
              {recentEntries[1]?.blockers && (
                <div class="rounded-lg border border-amber-400/20 bg-amber-500/10 p-3">
                  <p class="mb-0.5 text-xs font-medium tracking-wide text-amber-300/60 uppercase">Previous day</p>
                  <p class="text-sm text-amber-100/90">{recentEntries[1].blockers}</p>
                </div>
              )}
            </div>
            <div class="flex gap-3">
              <form method="POST" action="/api/blocker/confirm">
                <input type="hidden" name="trigger_date" value={todayEntry.submitted_date} />
                <button
                  type="submit"
                  class="rounded-lg border border-amber-400/40 bg-amber-500/20 px-4 py-2 text-sm font-medium text-amber-200 transition hover:bg-amber-500/30"
                >
                  Yes, same blocker
                </button>
              </form>
              <form method="POST" action="/api/blocker/dismiss">
                <input type="hidden" name="trigger_date" value={todayEntry.submitted_date} />
                <button
                  type="submit"
                  class="rounded-lg border border-white/20 bg-white/5 px-4 py-2 text-sm font-medium text-blue-100/70 transition hover:bg-white/10"
                >
                  No, different issue
                </button>
              </form>
            </div>
          </section>
        )
      }

      <!-- Edit/delete success flash -->
      {
        successMessage && (
          <div class="rounded-xl border border-green-400/30 bg-green-500/10 px-4 py-3 text-sm text-green-300">
            {successMessage}
          </div>
        )
      }

      <!-- Standup: form or today's read-only entry -->
      <section class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl">
        {
          todayEntry ? (
            <div>
              <div class="mb-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-blue-100">Today's standup</h2>
                <span class="rounded-full border border-green-400/40 bg-green-500/20 px-3 py-0.5 text-xs font-medium text-green-300">
                  Submitted ✓
                </span>
              </div>
              <div class="space-y-4">
                <div>
                  <p class="mb-1 text-xs font-medium tracking-wide text-blue-100/50 uppercase">What you did</p>
                  <p class="text-sm whitespace-pre-wrap text-blue-100/90">{todayEntry.did}</p>
                </div>
                <div>
                  <p class="mb-1 text-xs font-medium tracking-wide text-blue-100/50 uppercase">Plan for today</p>
                  <p class="text-sm whitespace-pre-wrap text-blue-100/90">{todayEntry.plan}</p>
                </div>
                {todayEntry.blockers && (
                  <div>
                    <p class="mb-1 text-xs font-medium tracking-wide text-blue-100/50 uppercase">Blockers</p>
                    <p class="text-sm whitespace-pre-wrap text-blue-100/90">{todayEntry.blockers}</p>
                  </div>
                )}
              </div>
            </div>
          ) : (
            <div>
              <h2 class="mb-4 text-lg font-semibold text-blue-100">Submit today's standup</h2>
              <StandupForm serverError={submitError} client:load />
            </div>
          )
        }
      </section>

      <!-- History list -->
      <StandupHistoryList entries={displayEntries} blockerAlerts={blockerAlerts} client:load />
    </main>
  </div>
</AppLayout>
