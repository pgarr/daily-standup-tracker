---
import Layout from "@/layouts/Layout.astro";
import WorkspaceSetupForm from "@/components/workspace/WorkspaceSetupForm";

const { workspaceMember } = Astro.locals;

if (workspaceMember) {
  return Astro.redirect("/dashboard");
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="Set up workspace">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Create your workspace
      </h1>
      <p class="mb-6 text-center text-sm text-blue-100/60">Give your team a home. You can change this later.</p>
      <WorkspaceSetupForm serverError={error} client:load />
    </div>
  </div>
</Layout>
